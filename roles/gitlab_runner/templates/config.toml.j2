concurrent = {{ gitlab_runner_concurrent }}
check_interval = {{ gitlab_runner_check_interval }}
shutdown_timeout = 0

[session_server]
  session_timeout = 1800

[[runners]]
  name = "{{ gitlab_runner_name }}"
  url = "{{ gitlab_url }}"
  id = 0
  token = "{{ gitlab_runner_token }}"
  token_obtained_at = "0001-01-01T00:00:00Z"
  token_expires_at = "0001-01-01T00:00:00Z"
  executor = "{{ gitlab_runner_executor }}"
  environment = ["DOCKER_TLS_CERTDIR="]

  [runners.custom_build_dir]

  [runners.cache]
    MaxUploadedArchiveSize = 0
    [runners.cache.s3]
    [runners.cache.gcs]
    [runners.cache.azure]

  [runners.docker]
    tls_verify = false
    image = "{{ gitlab_runner_docker_image }}"
    privileged = false
    disable_entrypoint_overwrite = false
    oom_kill_disable = false
    disable_cache = false
    volumes = ["/cache"]
    shm_size = 0
    network_mtu = 0

  # ── SSL / TLS configuration ────────────────────────────────────────────
  # Points to the full-chain cert named after the GitLab hostname, which
  # the certificates role deployed automatically.
  tls-ca-file = "{{ cert_gitlab_runner_ssl_dir }}/{{ gitlab_url | urlsplit('hostname') }}.crt"
